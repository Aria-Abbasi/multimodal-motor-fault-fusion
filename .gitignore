# Python
__pycache__/
*.py[cod]
*.so
.pytest_cache/
.mypy_cache/

# Virtual environments
.venv/
venv/

# OS/editor
.DS_Store
.idea/
.vscode/

# Build artifacts
build/
dist/
*.egg-info/

# Logs and runtime artifacts
artifacts/logs/*.log
artifacts/checkpoints/*
results/runs/*
results/tables/*
results/figures/*

# Keep directory structure via .gitkeep
!artifacts/logs/.gitkeep
!artifacts/checkpoints/.gitkeep
!results/runs/.gitkeep
!results/tables/.gitkeep
!results/figures/.gitkeep

# Data: never commit raw datasets
data/raw/**
!data/raw/**/.gitkeep

# Generated data (safe default: ignore contents, keep dirs)
data/interim/**
data/processed/**
data/metadata/**
data/splits/**
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/metadata/.gitkeep
!data/splits/.gitkeep
